{
  "manifest_version": 3,
  "name": "Abid TTS Automation",
  "version": "1.3.0",
  "description": "Professional Reading Automation for MargVoice.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://margvoice.com/projects/execute/reading*"
      ],
      "js": [
        "patch.js",
        "utils.js",
        "selectors.js",
        "tts.js",
        "automation.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
